# ============================================================
# Lintro Marketplace - Environment Variables
# ============================================================

# Django Core
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.onrender.com,.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://Lintro.vercel.app
# BUG-016 fix: CSRF trusted origins (used by Django admin / session auth)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://Lintro.vercel.app

# Database
# Use sqlite for development, postgres for production
DATABASE_URL=sqlite:///db.sqlite3
# Postgres example (Neon):
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# JWT
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (use console in dev, SMTP in prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@Lintro.in

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# Twilio (optional - SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Rate Limiting
RATE_LIMIT_LOGIN=5/h
RATE_LIMIT_REGISTER=3/h
RATE_LIMIT_OTP=3/h

# System Defaults
DEFAULT_LISTING_EXPIRY_DAYS=30
DEFAULT_MAX_IMAGES=5
DEFAULT_24HR_ACTION_HOURS=24
DEFAULT_7DAY_CLEANUP_DAYS=7
